POSTGRES_DB=eatco
POSTGRES_USER=eatco
POSTGRES_PASSWORD=eatco_dev_password

# 식품의약품안전처 API 키 (식품안전나라 레시피 API)
# 발급: https://www.foodsafetykorea.go.kr/api/openApiInfo.do
RECIPE_API_KEY=

# 공공데이터포털 API 키
# 발급: https://www.data.go.kr/
DATA_GO_KR_API_KEY=

# JWT 인증 시크릿 (프로덕션에서 반드시 변경)
SECRET_KEY=eatco-dev-only-change-in-production

# OCR 설정 — gemini 권장 (clova, mock 도 가능)
OCR_PROVIDER=gemini
OCR_MOCK_MODE=false

# Google Gemini API 키 (영수증 스캔용, 권장)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Naver CLOVA OCR (대체 OCR, OCR_PROVIDER=clova 시 사용)
CLOVA_OCR_API_URL=
CLOVA_OCR_SECRET_KEY=

# 환경 설정 (development | production)
ENVIRONMENT=development

# Rate Limiting (개발 환경은 넉넉하게, 프로덕션은 타이트하게)
# 개발: 100/hour, 프로덕션 권장: 10/hour
RATE_LIMIT_SCAN=100/hour
# 개발: 200/hour, 프로덕션 권장: 20/hour
RATE_LIMIT_RECIPES=200/hour
